{
  "manifest_version": 3,
  "name": "Bamboo Job End Notifier",
  "version": "1.0",
    "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "description": "Audible chime when a Bamboo CI/CD build or deploy completes.",
"content_scripts": [
    {
      "matches": ["*://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
