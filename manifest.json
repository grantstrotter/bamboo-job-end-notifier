{
    "manifest_version": 3,
    "name": "Bamboo Job End Notifier",
    "version": "1.2",
    "icons": {
        "16": "icon16.png",
        "48": "icon48.png",
        "128": "icon128.png"
    },
    "description": "Audible notification when a Bamboo CI/CD build or deploy completes.",
    "content_scripts": [
        {
            "matches": [
                "*://*/*"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_idle"
        }
    ],
    "permissions": [
        "notifications",
        "offscreen",
        "storage"
    ],
    "background": {
        "service_worker": "background.js"
    }
}